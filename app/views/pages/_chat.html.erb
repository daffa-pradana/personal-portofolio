<section id="chat" class="py-24 px-6 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <p class="text-sm font-medium text-gray-500 uppercase tracking-widest mb-2">Know More About Me</p>
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-10">Chat with AI</h2>

    <div class="grid md:grid-cols-5 gap-8">
      <%# Left: suggested questions %>
      <div class="md:col-span-2 space-y-3">
        <p class="text-sm font-medium text-gray-500 mb-4">Suggested questions</p>
        <% [
          "What's Daffa's tech stack?",
          "Tell me about Daffa's experience",
          "What projects has Daffa worked on?",
          "How can I contact Daffa?"
        ].each do |question| %>
          <button class="w-full text-left px-4 py-3 bg-white border border-gray-200 rounded-xl text-sm text-gray-700 hover:border-gray-400 hover:shadow-sm transition-all"
                  data-action="click->chat#suggest"
                  data-question="<%= question %>">
            <%= question %>
          </button>
        <% end %>
      </div>

      <%# Right: chat interface %>
      <div class="md:col-span-3 flex flex-col bg-white rounded-2xl border border-gray-200 overflow-hidden"
           data-controller="chat"
           style="height: 480px;">
        <div class="px-5 py-3 border-b border-gray-100">
          <p class="text-xs text-gray-400">Ask me anything about Daffa — keep it short for quick answers.</p>
        </div>

        <%# Messages area %>
        <div class="flex-1 overflow-y-auto px-5 py-4 space-y-4"
             data-chat-target="messages">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-7 h-7 rounded-full bg-gray-900 flex items-center justify-center text-white text-xs font-bold">AI</div>
            <div class="bg-gray-100 rounded-2xl rounded-tl-sm px-4 py-2 text-sm text-gray-700 max-w-xs">
              Hi! I'm Daffa's AI assistant. Ask me anything about his experience, skills, or projects.
            </div>
          </div>
        </div>

        <%# Typing indicator (hidden by default) %>
        <div class="hidden px-5 pb-2" data-chat-target="typing">
          <div class="flex items-center gap-3">
            <div class="flex-shrink-0 w-7 h-7 rounded-full bg-gray-900 flex items-center justify-center text-white text-xs font-bold">AI</div>
            <div class="bg-gray-100 rounded-2xl rounded-tl-sm px-4 py-2">
              <div class="flex gap-1 items-center h-4">
                <span class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
                <span class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
                <span class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
              </div>
            </div>
          </div>
        </div>

        <%# Input area %>
        <div class="border-t border-gray-100 px-4 py-3 flex gap-2">
          <%= form_with url: "/chat", data: { action: "submit->chat#sendMessage", chat_target: "form" }, class: "flex gap-2 w-full" do |f| %>
            <%= f.text_field :message,
                placeholder: "Ask about Daffa...",
                autocomplete: "off",
                class: "flex-1 text-sm border border-gray-200 rounded-full px-4 py-2 focus:outline-none focus:border-gray-400",
                data: { chat_target: "input" } %>
            <%= f.submit "Send",
                class: "px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-full hover:bg-gray-700 transition-colors cursor-pointer" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
