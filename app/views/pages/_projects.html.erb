<section id="projects" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <p class="text-sm font-medium text-gray-500 uppercase tracking-widest mb-2">What I've been working on</p>
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-10">My Latest Projects</h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @projects.each do |project| %>
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
          <div class="h-44 bg-gray-100 flex items-center justify-center text-gray-300">
            <%# TODO: replace with project.image once Active Storage is set up %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="p-5">
            <h3 class="font-semibold text-gray-900 mb-2"><%= project.title %></h3>
            <p class="text-sm text-gray-500 mb-4 line-clamp-2"><%= project.description %></p>
            <div class="flex flex-wrap gap-2 mb-4">
              <% project.tags.each do |tag| %>
                <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs font-medium rounded-full"><%= tag %></span>
              <% end %>
            </div>
            <div class="flex gap-2">
              <% if project.live_url.present? %>
                <a href="<%= project.live_url %>" target="_blank" rel="noopener noreferrer"
                   class="text-xs font-medium px-3 py-1.5 bg-gray-900 text-white rounded-full hover:bg-gray-700 transition-colors">
                  Live Demo
                </a>
              <% end %>
              <% if project.source_code_url.present? %>
                <a href="<%= project.source_code_url %>" target="_blank" rel="noopener noreferrer"
                   class="text-xs font-medium px-3 py-1.5 border border-gray-300 text-gray-700 rounded-full hover:border-gray-500 transition-colors">
                  Source
                </a>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
